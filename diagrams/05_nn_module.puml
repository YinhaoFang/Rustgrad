@startuml NN Module Hierarchy
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 13
title 神经网络组件

interface Module {
  + forward(input: &Tensor) : Result<Tensor>
  + parameters() : Vec<&Tensor>
  + parameters_mut() : Vec<&mut Tensor>
  + name() : &str
}

class Linear {
  - input_size: usize
  - output_size: usize
  - weights: Tensor  // [in, out]
  - bias: Tensor     // [out]
  --
  + new(input_size, output_size) : Result<Self>
  + with_parameters(weights, bias) : Result<Self>
  + forward(input) : Result<Tensor>
  --
  <i>output = input @ weights + bias</i>
  <i>支持向量 (自动 reshape) 和矩阵输入</i>
}

class Sequential {
  - layers: Vec<Box<dyn Module>>
  --
  + new() : Self
  + push(module)
  + len() : usize
  + forward(input) : Result<Tensor>
  --
  <i>依次应用每层: x → L1 → L2 → ... → output</i>
  <i>parameters() 递归收集所有子层参数</i>
}

class ActivationLayer {
  - activation: Activation
  --
  + new(activation) : Self
  + forward(input) : Result<Tensor>
}

enum Activation {
  Relu
  Sigmoid
  Tanh
  Softmax
  --
  + apply(input) : Result<Tensor>
  + name() : &str
}

Module <|.. Linear
Module <|.. Sequential
Module <|.. ActivationLayer

Sequential "1" *-- "0..*" Module : layers
ActivationLayer --> Activation

note right of Linear
  <b>权重初始化</b>
  确定性 pattern:
  对称模式 × 缩放因子
  scale = sqrt(2/(in+out))
end note

note bottom of Activation
  <b>数值稳定性</b>
  Sigmoid: 分段实现防溢出
  Softmax: 减 max 防 exp 爆炸
  导数基于输出值避免重复 exp
end note

@enduml
