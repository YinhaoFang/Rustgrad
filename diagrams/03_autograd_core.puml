@startuml Autograd Core
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 13
title 自动求导核心类型

enum Operation {
  Leaf
  Add
  Sub
  Mul
  Div
  MatMul
  Transpose
  Sum
  Mean
  RowAdd
  Relu
  Sigmoid
  Tanh
  Softmax
  Custom(String)
  --
  + name() : &str
}

class NodeId {
  - id: usize
  --
  + new(index) : NodeId
  + index() : usize
}

class GraphNode {
  - id: NodeId
  - value: Tensor
  - parents: Vec<NodeId>
  - operation: Operation
  - requires_grad: bool
  - grad: Option<Tensor>
  --
  + leaf(id, value, requires_grad) : Self
  + operation(id, value, parents, op, requires_grad) : Self
  + id() : NodeId
  + value() : &Tensor
  + parents() : &[NodeId]
  + operation_kind() : &Operation
  + requires_grad() : bool
  + grad() : Option<&Tensor>
  + set_grad(grad)
  + accumulate_grad(grad) : Result<()>
  + take_grad() : Option<Tensor>
  + clear_grad()
}

class ComputationGraph {
  - nodes: Vec<GraphNode>
  --
  + new() : Self
  + len() : usize
  + add_leaf(value, requires_grad) : NodeId
  + add_operation(op, parents, value, requires_grad) : Result<NodeId>
  + node(id) : Option<&GraphNode>
  + topological_order(output) : Result<Vec<NodeId>>
  + backward(output) : Result<()>
  + backward_with_grad(output, seed) : Result<()>
  + take_gradients() : Vec<Tensor>
  + clear_gradients()
  --
  - local_gradients(id, upstream) : Result<Vec<(NodeId, Tensor)>>
  - add_gradients / sub_gradients / mul_gradients / div_gradients
  - matmul_gradients / sum_gradient / mean_gradient
  - row_add_gradients / transpose_gradient
  - relu_gradient / sigmoid_gradient / tanh_gradient / softmax_gradient
}

ComputationGraph "1" *-- "0..*" GraphNode
GraphNode "1" --> "0..2" NodeId : parents
GraphNode --> Operation : operation
NodeId "1" --* GraphNode : id

note right of ComputationGraph::backward_with_grad
  <b>关键设计</b>
  训练循环手工计算损失梯度
  作为种子传入,
  autograd 自动传播到参数
end note

note bottom of Operation
  <b>12 种内置操作
  全部有梯度规则</b>
  自定义操作通过 Custom(String)
  扩展, 返回 UnsupportedOperation
end note

@enduml
