@startuml Backward Flow
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 13
title 反向传播序列

participant "训练循环" as train
participant "ComputationGraph" as graph
participant "GraphNode (输出)" as out
participant "GraphNode (中间)" as mid
participant "GraphNode (叶子/参数)" as leaf
participant "优化器" as optim

== 第 1 步: 进行前向计算, 构建图 ==
train -> graph: add_leaf(features, requires_grad=false)
train -> graph: add_leaf(weights, requires_grad=true)
train -> graph: add_leaf(bias, requires_grad=true)
train -> graph: add_operation(MatMul, ...)
train -> graph: add_operation(RowAdd, ...)
train -> graph: add_operation(Sigmoid, ...)

== 第 2 步: 手工计算损失梯度作为种子 ==
train -> train: dL/dy = (σ(z)-target)/N
note right: 损失梯度手工解析计算\n公式简洁, 易于教学验证

== 第 3 步: 种子传入, 反向传播 ==
train -> graph: backward_with_grad(output_node, seed_grad)
graph -> out: accumulate_grad(seed)
graph -> graph: topological_order(output)
graph -> graph: 逆序遍历拓扑序列

loop 每个节点
  graph -> graph: local_gradients(node_id, upstream_grad)
  note right
    查表匹配操作类型:
    Sigmoid → sigmoid_gradient
    RowAdd → row_add_gradients
    MatMul → matmul_gradients
    Leaf → (空, 停止)
  end note
  graph -> mid: accumulate_grad(parent_grad)
  graph -> leaf: accumulate_grad(parent_grad)
end

== 第 4 步: 取出参数梯度 ==
train -> graph: take_gradients()
graph --> train: [weight_grad, bias_grad]

== 第 5 步: 优化器更新参数 ==
train -> optim: step(&mut parameters, &gradients)
optim -> optim: θ -= lr * g

@enduml
